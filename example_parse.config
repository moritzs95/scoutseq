#!/usr/bin/env bash

# Paths can be absolute or relative to this config file.
R1="./data/scOUT_Parse_seq_example_R1.fastq.gz"
R2="./data/scOUT_Parse_seq_example_R2.fastq.gz"

# Output folder settings.
SAMPLENAME="Parse_example"
OUTPUTDIR=""          # Optional full output folder path; defaults to <workspace>/<SAMPLENAME>
FORCE="TRUE"
START_AT="seq_filter" # Optional: seq_filter, barcode_extract, parse_annotate, split_hdr, crispresso, crispresso_filter, hdr_postprocessing
STOP_AFTER=""         # Optional: stop after a given stage using the same names as START_AT

# Library settings.
LIBTYPE="PARSE"       # "10X", "PARSE", or "BDR"
PARSEKIT=""           # Optional: set to "mini" for mini PARSE kits, default is mega
EXPECTEDCELLS=""
SETCELLNUMBER=100
BCPATTERN=""
EXTRACTMETHOD=""
BDR_DIR=""

# Optional pre-filter for merged R2 sequences.
SEQFILTER=""
CRISPRESSOFILTER=""

# CRISPResso settings.
TARGET="Son_sg4"
AMPLICONSEQ="GATAGACGTAAATAAAAATGCTGTAACCGACTTATCTAATAAAAATTGGCACCCAGCCGCTATTTTGTTGACTGAGGAAGTTTATGTTAATTTTTTAGGGTCTGATAGAATATTCATGTGTATTACAGTGGTATTCATATGCTATGTCTCTAAACTTTATTTTCAAAAGCTTAAGGCCCAAATACAAACTTCTCTGGAAT"
HDRSEQ=""
GUIDE="CAGTCAACAAAATAGCGGCT"
CRISPRESSOWINDOW=25

# HDR barcode handling.
FILTERHDRREADSCONFIG="./parse_hdr_filter_example.ini"
HDRBCTYPE=""
HDRBCLENGTH=15

# Downstream annotation settings.
DROTARGET="Son_sg4"
DRO_LEFT_ANCHOR="CACCCAGC"
DRO_RIGHT_ANCHOR="CGCTATTTTG"
DRO_HDR_ANCHOR="GGCATGC"
DRO_WT_AMPLICON="GATAGACGTAAATAAAAATGCTGTAACCGACTTATCTAATAAAAATTGGCACCCAGCCGCTATTTTGTTGACTGAGGAAGTTTATGTTAATTTTTTAGGGTCTGATAGAATATTCATGTGTATTACAGTGGTATTCATATGCTATGTCTCT"
DRO_WT_AMPLICON_AFTER_CUTSITE="CGCTATTTTGTTGACTGAGGAAGTTTATGTTAATTTTTTAGGGTCTGATAGAATATTCATGTGTATTACAGTGGTATTCATATGCTATGTCTCTAAACTTTATTTTCAAAAGCTTAAGGCCCAAATACAAACTTCTCTGGAAT"
DRO_GS_PRIMER="GATAGACGTAAATAAAAATGCTGTAAC"
DRO_CDNA_LENGTH=203
DRO_REFERENCE_LENGTH=200
DRO_INSERTION_TYPE="substitution"
DRO_THRESHOLD_I90PLUS=30
DRO_THRESHOLD_D90PLUS=30
DRO_THRESHOLD_S1PLUS=50
DROREADLENGTH=151
CBCPATH="./cell_metadata_parse/"
SPECIES="mouse"
GENOME_DIR="./genome"
AAV_GENOME_DIR="./genome/AAVB2mdTomato.fasta"  # Optional: set to an AAV FASTA or folder containing AAV*.fa/AAV*.fasta.
CHRTARGET="chr16"
STARTTARGET=91678993
ENDTARGET=91679192
