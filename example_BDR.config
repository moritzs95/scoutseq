#!/usr/bin/env bash

# Paths can be absolute or relative to this config file.
# This example uses a downsampled BD Rhapsody subset
R1="./data/scOUT_BDR_seq_example_R1.fastq.gz"
R2="./data/scOUT_BDR_seq_example_R2.fastq.gz"

# Output folder settings.
SAMPLENAME="BDR_example"
OUTPUTDIR=""           # Optional full output folder path; defaults to <workspace>/<SAMPLENAME>
FORCE="TRUE"
START_AT="seq_filter"  # Optional: seq_filter, barcode_extract, parse_annotate, split_hdr, crispresso, crispresso_filter, hdr_postprocessing
STOP_AFTER=""          # Optional: stop after a given stage using the same names as START_AT

# Library settings.
LIBTYPE="BDR"         # "10X", "PARSE", or "BDR"
PARSEKIT=""
EXPECTEDCELLS=""
SETCELLNUMBER=106
BCPATTERN=""          # Leave empty to use the built-in BD Rhapsody regex
EXTRACTMETHOD=""      # Optional for BDR, defaults to "regex"
BDR_DIR="./BDR_helpers"

# Optional pre-filter for merged R2 sequences.
SEQFILTER=""
CRISPRESSOFILTER=""

# CRISPResso settings.
TARGET="GAPDH_sg13_151nt"
AMPLICONSEQ="GTCCCTGCCACACTCAGTCCCCCACCACACTGAATCTCCCCTCCTCACAGTTGCCATGTAGACCCCTTGAAGAGGGGAGGGGCCTAGGGAGCCGCACCTTGTCATGTACCATCAATAAAGTACCCTGTGCTCAACCAGTTACTTGTCCTGTCTTATTCTAGGGTCTGGGGCAGAGGGGAGGGAAGCTGGGCTTGTGTCAA"
HDRSEQ=""
GUIDE="GGGTCTACATGGCAACTGTG"
CRISPRESSOWINDOW=25

# HDR barcode handling.
FILTERHDRREADSCONFIG="./bdr_hdr_filter_example.ini"
HDRBCTYPE=""
HDRBCLENGTH=15

# Downstream annotation settings.
DROTARGET="GAPDH_sg13"
DRO_LEFT_ANCHOR="CTCCTCAC"
DRO_RIGHT_ANCHOR="AGTTGCCATG"
DRO_HDR_ANCHOR="CTCCCCTTGT"
DRO_WT_AMPLICON="GTCCCTGCCACACTCAGTCCCCCACCACACTGAATCTCCCCTCCTCACAGTTGCCATGTAGACCCCTTGAAGAGGGGAGGGGCCTAGGGAGCCGCACCTTGTCATGTACCATCAATAAAGTACCCTGTGCTCAACCAGTTACTTGTCCTGT"
DRO_WT_AMPLICON_AFTER_CUTSITE="AGTTGCCATGTAGACCCCTTGAAGAGGGGAGGGGCCTAGGGAGCCGCACCTTGTCATGTACCATCAATAAAGTACCCTGTGCTCAACCAGTTACTTGTCCTGTCTTATTCTAGGGTCTGGGGCAGAGGGGAGGGAAGCTGGGCTTGTGTCAA"
DRO_GS_PRIMER="GTCCCTGCCACACTCAGTCCCCC"
DRO_CDNA_LENGTH=137
DRO_REFERENCE_LENGTH=200
DRO_INSERTION_TYPE="substitution"
DRO_THRESHOLD_I90PLUS=30
DRO_THRESHOLD_D90PLUS=30
DRO_THRESHOLD_S1PLUS=50
DROREADLENGTH=151
CBCPATH="./cell_metadata_BDR/"
SPECIES="human"
GENOME_DIR="./genome"
CHRTARGET="chr12"
STARTTARGET=6538235
ENDTARGET=6538434
